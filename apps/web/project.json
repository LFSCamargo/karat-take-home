{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web/src",
  "projectType": "application",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite apps/web --host 0.0.0.0"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build apps/web"
      },
      "outputs": ["{workspaceRoot}/dist/apps/web"]
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite preview apps/web"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config apps/web/vitest.config.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint apps/web && tsc -p apps/web/tsconfig.app.json --noEmit && tsc -p apps/web/tsconfig.spec.json --noEmit"
      }
    }
  }
}
