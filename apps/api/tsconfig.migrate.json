{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "types": ["node"],
    "composite": true
  },
  "include": [
    "src/config/env.ts",
    "src/config/load-env.ts",
    "src/db/migrate.ts",
    "src/db/migrate-runner.ts",
    "src/db/migrations/**/*.ts",
    "src/db/client.ts",
    "src/db/schema.ts",
    "src/db/connection-url.ts"
  ]
}
