{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "types": ["node"],
    "noEmit": false,
    "outDir": "../../dist/apps/api",
    "rootDir": "./src",
    "declaration": true,
    "sourceMap": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.test.ts",
    "src/db/migrate.ts",
    "src/db/migrate-runner.ts",
    "src/db/migrations/**/*.ts",
    "src/scripts/**/*.ts",
    "src/test/**/*.ts"
  ]
}
