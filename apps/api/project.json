{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx watch apps/api/src/main.ts"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx watch apps/api/src/main.ts"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/api/tsconfig.app.json"
      },
      "outputs": ["{workspaceRoot}/dist/apps/api"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config apps/api/vitest.config.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint apps/api && tsc -p apps/api/tsconfig.app.json --noEmit && tsc -p apps/api/tsconfig.spec.json --noEmit && tsc -p apps/api/tsconfig.node.json --noEmit && tsc -p apps/api/tsconfig.migrate.json --noEmit"
      }
    },
    "migrate": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "tsx apps/api/src/db/migrate.ts"
      }
    },
    "migrate:test": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "tsx apps/api/src/db/migrate.ts"
      },
      "env": {
        "DATABASE_URL": "postgresql://postgres:postgres@localhost:5432/app_db_test"
      }
    },
    "migrate:down": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx apps/api/src/db/migrate.ts down"
      }
    }
  }
}
