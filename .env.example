# Copy to `.env` at the repo root and adjust values for local development.
# Both `apps/api` and `apps/web` read from this file.
#
# Docker Compose (`docker compose up --build`) loads this file for api and web.
# Compose overrides POSTGRES_HOST and DATABASE_URL inside containers so the api
# can reach the `db` service. Keep VITE_PUBLIC_API_URL as http://localhost:3333
# so the browser on your host can reach the published API port.

# -----------------------------------------------------------------------------
# Shared / PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# App database (docker-compose creates `app_db` and `app_db_test`)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_db
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_db_test

# -----------------------------------------------------------------------------
# API (backend)
# -----------------------------------------------------------------------------
PORT=3333

# Local development cardholder context (Stripe ich_... or local UUID).
# Maps to cardholders.external_user_id when using an ich_ id.
DEFAULT_CARDHOLDER_ID=

# Stripe Issuing
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional default for `pnpm stripe:trigger` (Stripe cardholder id ich_...)
# STRIPE_CARDHOLDER_ID=

# -----------------------------------------------------------------------------
# Web (frontend) — only `VITE_PUBLIC_*` vars are exposed to the browser
# -----------------------------------------------------------------------------
VITE_PUBLIC_API_URL=http://localhost:3333
VITE_PUBLIC_USE_MOCK_DATA=true
